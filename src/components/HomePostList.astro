---
import type { Post } from '../lib/site';
import { postDate, postPath, postReadingTime, readingTimeStrength } from '../lib/site';

interface Props {
  posts: Post[];
  limit?: number;
}
const { posts, limit } = Astro.props;
const displayed = limit === undefined ? posts : posts.slice(0, limit);
const years = new Map<number, Post[]>();
for (const post of displayed) {
  const year = postDate(post).getUTCFullYear();
  years.set(year, [...(years.get(year) ?? []), post]);
}

---

<div class="mt-10 not-prose">
  {[...years.entries()].map(([year, yearPosts]) => (
    <section class="mb-6">
      <h3 class="mb-1 text-sm font-normal text-neutral-400">{year}</h3>
      <ul class="list-none p-0">
        {yearPosts.map((post) => (
          <li>
            <a class="group flex flex-col items-start gap-1 py-1.5 text-black sm:flex-row sm:items-baseline sm:justify-between sm:gap-6 dark:text-white" href={postPath(post)}>
              <span class="group-hover:underline">{post.data.title}</span>
              <time class="shrink-0 text-sm text-neutral-500" datetime={postDate(post).toISOString()}>{postDate(post).toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' })} / <span class="reading-time" style={`--reading-time-strength: ${readingTimeStrength(postReadingTime(post))}`}>{postReadingTime(post)} min read</span></time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>
