---
import type { Post } from '../lib/site';
import { postDate, postPath } from '../lib/site';

interface Props {
  posts: Post[];
  limit?: number;
}
const { posts, limit } = Astro.props;
const displayed = limit === undefined ? posts : posts.slice(0, limit);
---

<div class="mt-16">
  {displayed.map((post) => (
    <article class="mb-16">
      <h2 class="!m-0 !mb-1 !text-xl lg:!text-2xl !font-medium">
        <a class="text-black dark:text-white no-underline hover:underline" href={postPath(post)}>{post.data.title}</a>
      </h2>
      <div class="text-sm lg:text-base text-gray-500">
        {postDate(post).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
        {post.collection === 'mini' && <>&nbsp;&middot;&nbsp;<a href={postPath(post)}>Permalink</a></>}
      </div>
      {post.collection === 'blog' && <div class="mt-4"><a class="inline-block !no-underline !text-blue-500 hover:underline" href={postPath(post)}>Keep reading <span aria-hidden="true">↗</span></a></div>}
    </article>
  ))}
</div>
