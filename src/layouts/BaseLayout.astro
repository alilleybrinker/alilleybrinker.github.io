---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  feed?: string;
}
const {
  title: pageTitle,
  description = 'I work on software security at MITRE, including serving as a member of the OmniBOR Working Group and leading development of the Rust implementation.',
  canonical = new URL(Astro.url.pathname, Astro.site),
  feed = '/rss.xml',
} = Astro.props;
const title = pageTitle ? `${pageTitle} — Andrew Lilley Brinker` : 'Andrew Lilley Brinker';
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Andrew Lilley Brinker" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={feed} />
  </head>
  <body class="bg-stone-50 dark:bg-neutral-900">
    <div class="subpixel-antialiased">
      <header class="pt-32 pb-0 mb-4 text-black dark:text-neutral-100 text-base md:text-lg px-5 md:px-0 md:max-w-(--breakpoint-md) md:mx-auto">
        <nav class="font-normal">
          <ul class="m-0 list-none p-0 md:flex md:items-center gap-6 md:gap-8">
            <li class="block md:flex md:items-center mb-4 md:mb-0"><a href="/" class="inline-flex items-center gap-2 whitespace-nowrap leading-none hover:underline font-semibold"><img src="/image/andrew_lineart-transparent.png" alt="" class="size-16 rounded-full dark:bg-neutral-300 md:-ml-[4.5rem]" />Andrew Lilley Brinker</a></li>
            <li class="inline md:flex md:items-center"><ul class="m-0 inline-flex items-center list-none p-0 md:flex gap-4 md:gap-8"><li><a href="/about/" class="inline-flex items-center leading-none hover:underline">About</a></li><li><a href="/blog/" class="inline-flex items-center leading-none hover:underline">Blog</a></li></ul></li>
            <li class="ml-auto md:-mr-6 md:flex md:items-center"><ul class="m-0 flex items-center list-none p-0 gap-2"><li><a href="https://bsky.app/profile/alilleybrinker.com" aria-label="Bluesky" class="flex size-8 items-center justify-center text-neutral-400 hover:text-blue-500"><Icon name="bluesky" class="!h-5 !w-5" /></a></li><li><a href="https://github.com/alilleybrinker" aria-label="GitHub" class="flex size-8 items-center justify-center text-neutral-400 hover:text-blue-500"><Icon name="github" class="!h-5 !w-5" /></a></li></ul></li>
            <li class="md:flex md:items-center"><ThemeSwitcher /></li>
          </ul>
        </nav>
      </header>
      <main class="pt-12 pb-24 px-5 md:px-0 md:max-w-(--breakpoint-md) md:mx-auto"><div class="mb-12 prose lg:prose-lg lg:leading-relaxed prose-stone dark:prose-invert prose-headings:font-medium prose-h1:font-display prose-headings:text-black dark:prose-headings:text-neutral-100 prose-a:text-black dark:prose-a:text-white prose-a:font-normal prose-a:decoration-1 prose-a:underline-offset-2 prose-a:decoration-blue-400 prose-a:hover:decoration-black dark:prose-a:hover:decoration-white prose-code:after:content-none prose-code:before:content-none prose-blockquote:font-normal prose-blockquote:not-italic prose-figure:bg-white dark:prose-figure:bg-neutral-800 prose-figure:rounded-xl prose-figure:shadow-lg prose-pre:p-5 lg:prose-pre:p-8 prose-pre:-mx-5 lg:prose-pre:-mx-8 md:prose-pre:rounded-3xl text-pretty max-w-full"><slot /></div><footer class="mt-8 text-xs text-neutral-400"><p>Copyright Andrew Lilley Brinker. Made with <Icon name="heart" class="-mt-0.5 !h-3 !w-3" /> in California</p></footer></main>
    </div>
  </body>
</html>
