---
import { getCollection } from 'astro:content';
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePostList from '../../components/HomePostList.astro';
import { byNewest, topicSlug } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const topics = [...new Set(posts.flatMap((post) => post.data.taxonomies.topics))];
  return topics.map((topic) => ({ params: { topic: topicSlug(topic) }, props: { topic, posts: posts.filter((post) => post.data.taxonomies.topics.includes(topic)).sort(byNewest) } }));
}
const { topic, posts } = Astro.props;
---

<BaseLayout title={`${topic} Posts`} feed={`/topics/${topicSlug(topic)}/atom.xml`} socialImage={`/social/topic-${topicSlug(topic)}.png`} socialImageAlt={`${topic} Posts`}><h1><span class="mb-1 block font-sans text-base font-semibold uppercase tracking-widest text-slate-400">Topics</span>{topic}</h1><p><Icon name="rss" class="-mt-0.5 !h-4 !w-4" /> <a href="/atom.xml">All Posts</a> · <a href={`/topics/${topicSlug(topic)}/atom.xml`}>{topic} Posts</a></p><HomePostList posts={posts} /></BaseLayout>
