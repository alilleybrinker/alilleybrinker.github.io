---
import { getCollection } from 'astro:content';
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePostList from '../../components/HomePostList.astro';
import { byNewest, topicSlug } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const topics = [...new Set(posts.flatMap((post) => post.data.taxonomies.topics))];
  return topics.map((topic) => ({ params: { topic: topicSlug(topic) }, props: { topic, posts: posts.filter((post) => post.data.taxonomies.topics.includes(topic)).sort(byNewest) } }));
}
const { topic, posts } = Astro.props;
---

<BaseLayout title={`${topic} Posts`} feed={`/topics/${topicSlug(topic)}/atom.xml`} socialImage={`/social/topic-${topicSlug(topic)}.png`} socialImageAlt={`${topic} Posts`}>
  <div class="flex items-end justify-between">
    <h1 class="!mb-0"><span class="mb-1 block font-sans text-base font-semibold uppercase tracking-widest text-slate-400">Topics</span>{topic}</h1>
    <a class="not-prose text-neutral-400 hover:text-black dark:hover:text-white" href={`/topics/${topicSlug(topic)}/atom.xml`} aria-label={`RSS feed for ${topic} posts`}><Icon name="rss" class="!h-5 !w-5" /></a>
  </div>
  <HomePostList posts={posts} />
</BaseLayout>
