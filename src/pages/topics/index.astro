---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topicSlug } from '../../lib/site';
const posts = [...await getCollection('blog'), ...await getCollection('mini')];
const topics = Object.entries(posts.flatMap((post) => post.data.taxonomies.topics).reduce<Record<string, number>>((counts, topic) => ({ ...counts, [topic]: (counts[topic] ?? 0) + 1 }), {})).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Topics"><h1 class="!text-2xl !font-bold">Topics</h1><p>The following is a list of topics covered on my <a href="/blog/">Blog</a>. This includes <em>any</em> topic I’ve ever covered, sorted by decreasing frequency.</p><ul class="list-none not-prose ps-0"><li></li>{topics.map(([topic, count]) => <li class="py-2"><a class="font-normal block text-black dark:text-neutral-200 group" href={`/topics/${topicSlug(topic)}/`}><span class="inline-block mr-2 bg-stone-200 pt-1 pb-1 px-2 rounded-sm aspect-square h-6 text-center text-xs group-hover:bg-blue-500 group-hover:text-white dark:bg-neutral-700">{count}</span><span class="group-hover:underline">{topic}</span></a></li>)}</ul></BaseLayout>
