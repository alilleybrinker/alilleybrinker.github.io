---
const target = '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <script>window.location.replace('/');</script>
  </head>
  <body><p>Redirecting to <a href={target}>the homepage</a>.</p></body>
</html>
