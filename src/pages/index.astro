---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePostList from '../components/HomePostList.astro';
import { byNewest } from '../lib/site';
const posts = (await getCollection('blog')).sort(byNewest);
---

<BaseLayout title="Hi, my name is Andrew.">
  <p class="mb-24 font-medium text-black dark:text-neutral-100 [&_a]:!font-medium">I work on software security as a Principal Engineer at <a href="https://www.mitre.org">MITRE</a>, including working on the CVE system, leading development of <a href="https://mitre.github.io/hipcheck">Hipcheck</a>, and serving on the <a href="https://omnibor.io">OmniBOR</a> Core Team.</p>
  <section class="pb-4"><HomePostList posts={posts} /></section>
</BaseLayout>
