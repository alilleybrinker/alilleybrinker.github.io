---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePostList from '../components/HomePostList.astro';
import Icon from '../components/Icon.astro';
import { byNewest, postDate, postPath, postReadingTime, postSlug, readingTimeStrength, topicSlug } from '../lib/site';
const posts = (await getCollection('blog')).sort(byNewest);
const topics = Object.entries(
  posts.flatMap((post) => post.data.taxonomies.topics).reduce<Record<string, number>>(
    (counts, topic) => ({ ...counts, [topic]: (counts[topic] ?? 0) + 1 }),
    {},
  ),
).sort(([, countA], [, countB]) => countB - countA);
const startHere = [
  {
    slug: 'memory-safety-for-skeptics-in-the-acm-queue',
    title: 'Memory Safety for Skeptics',
    href: 'https://cacm.acm.org/practice/memory-safety-for-skeptics/',
    external: true,
    publication: 'CACM',
    publicationTitle: 'Communications of the ACM',
    date: new Date('2026-01-28T12:00:00Z'),
    readingTime: 30,
  },
  {
    slug: 'open-source-software-and-corporate-influence',
    title: 'Open Source Software and Corporate Influence',
  },
  {
    slug: 'cpp-must-become-safer',
    title: 'C++ Must Become Safer',
  },
];
const startHerePosts = startHere.map((entry) => {
  const post = posts.find((candidate) => postSlug(candidate) === entry.slug);
  if (!post) throw new Error(`Missing Start Here post: ${entry.slug}`);
  const date = 'date' in entry ? entry.date : postDate(post);
  const readingTime = 'readingTime' in entry ? entry.readingTime : postReadingTime(post);
  return {
    ...entry,
    href: 'href' in entry ? entry.href : postPath(post),
    description: post.data.description,
    date,
    readingTime,
    readingStrength: readingTimeStrength(readingTime),
  };
});
const otherPosts = posts.filter((post) => !startHere.some(({ slug }) => slug === postSlug(post)));
const lede = 'I’m a Principal Engineer at MITRE helping people make informed decisions about the software they depend on. I lead Hipcheck and contribute to the CVE system.';
---

<BaseLayout title="Software Security Engineer" description={lede} socialImage="/social/home.png" socialImageAlt="Software Security Engineer">
  <p class="!mb-12 font-medium text-black dark:text-neutral-100 [&_a]:!font-medium">I’m a Principal Engineer at <a href="https://www.mitre.org">MITRE</a> helping people make informed decisions about the software they depend on. I lead <a href="https://mitre.github.io/hipcheck">Hipcheck</a> and contribute to the <a href="https://www.cve.org/">CVE</a> system.</p>
  <section aria-labelledby="start-here-heading" class="not-prose mb-16">
    <h2 id="start-here-heading" class="mb-6 font-sans text-sm font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-400">Start Here</h2>
    <ul class="list-none space-y-6 p-0">
      {startHerePosts.map((post) => (
        <li>
          <a class="group block py-2 text-black dark:text-white" href={post.href}>
            <span class="flex flex-col items-start gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
              <span class="inline-flex items-center gap-1"><span class="group-hover:underline">{post.title}</span>{'publication' in post && <span title={post.publicationTitle} class="relative top-px mx-0.5 rounded-sm bg-stone-200/65 px-1.5 py-0.5 font-sans text-xs font-semibold text-stone-700 group-hover:bg-[#0085CA] group-hover:text-white dark:bg-neutral-500/70 dark:text-neutral-200">{post.publication}</span>}{post.external && <><Icon name="arrow-up-right" class="!h-4 !w-4 text-neutral-400 group-hover:text-black dark:text-neutral-500 dark:group-hover:text-white" /><span class="sr-only"> (external article)</span></>}</span>
              <time class="shrink-0 text-sm text-neutral-500" datetime={post.date.toISOString()}>{post.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })} / <span class="reading-time" style={`--reading-time-strength: ${post.readingStrength}`}>{post.readingTime} min read</span></time>
            </span>
            {post.description && <span class="mt-1 block max-w-[34rem] text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">{post.description}</span>}
          </a>
        </li>
      ))}
    </ul>
  </section>
  <section aria-labelledby="blog-heading" class="not-prose">
    <div class="flex items-center justify-between">
      <h2 id="blog-heading" class="font-sans text-sm font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-400">Blog</h2>
      <a href="/rss.xml" aria-label="RSS feed" class="text-neutral-400 hover:text-black dark:hover:text-white"><Icon name="rss" class="!h-5 !w-5" /></a>
    </div>
    <HomePostList posts={otherPosts} />
  </section>
  <section aria-labelledby="topics-heading" class="not-prose pb-4 pt-10">
    <h2 id="topics-heading" class="mb-6 font-sans text-sm font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-400">Topics</h2>
    <ul class="flex flex-wrap gap-x-4 gap-y-2 list-none p-0">
      {topics.map(([topic, count]) => (
        <li class="flex items-center" style="white-space: nowrap">
          <a class="group flex items-center" href={`/topics/${topicSlug(topic)}/`}>
            <span class="topic-link">{topic}</span>
            <span class="topic-badge ml-1.5 inline-flex size-[1.125rem] items-center justify-center rounded-full bg-stone-200 font-sans text-[10px] text-stone-700 dark:bg-neutral-700 dark:text-neutral-200">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
