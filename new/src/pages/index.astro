---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { byNewest } from '../lib/site';
const [blog, mini] = await Promise.all([getCollection('blog'), getCollection('mini')]);
---

<BaseLayout title="Hi, my name is Andrew.">
  <h1 class="block mb-10 text-3xl md:text-4xl"><span class="leading-snug block mb-4 font-display font-extrabold">Hi, my name is Andrew.</span></h1>
  <p class="text-xl leading-normal">I work on software security as a Principal Engineer at <a href="https://www.mitre.org">MITRE</a>, including working on the CVE system, leading development of <a href="https://mitre.github.io/hipcheck">Hipcheck</a>, and serving on the <a href="https://omnibor.io">OmniBOR</a> Core Team.</p>
  <p class="text-xl leading-normal">You can <a href="/about/#where-to-find-me">find me around</a>.</p>
  <section class="pb-4"><h2 class="!mb-0 !text-2xl lg:!text-3xl text-slate-700 dark:text-neutral-400">Latest Blog Posts</h2><PostList posts={blog.sort(byNewest)} limit={3} /></section>
  <section class="pb-4"><h2 class="!mb-0 !text-2xl lg:!text-3xl text-slate-700 dark:text-neutral-400">Latest Mini Posts</h2><PostList posts={mini.sort(byNewest)} limit={3} /></section>
</BaseLayout>
